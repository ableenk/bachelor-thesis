    "# The CCDDHNR2018 DGP touches the first three covariates, so dim_x >= 3 is required.\n",
    "ds_dml = data.make_doubleml_data(n=500, dim_x=5, seed=0)\n",
    "print('DoubleML dataset:  n =', ds_dml.n, ' d =', ds_dml.d,\n",
    "      ' mean Y =', ds_dml.Y.mean().round(3))"
   ]
  },
