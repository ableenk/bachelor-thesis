   "source": [
    "## 2. Cross-fitted residualization + R-learner\n",
    "\n",
    "We fit\n",
    "\n",
    "$$\\widehat\\tau_n \\in \\arg\\min_{\\tau\\in\\mathcal F_n}\n",
    "\\frac1n\\sum_i \\bigl(\\widetilde Y_i - \\widetilde A_i\\,\\tau(X_i)\\bigr)^2 + \\mathrm{pen}_n(\\tau),$$\n",
    "\n",
    "with $\\mathcal F_n$ a gradient-boosted-tree class (KRR is also available via `backend='krr'`)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "c3d0573b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "in-sample RMSE = 0.0261    sup-norm error ~ 0.1393\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1100x400 with 4 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "tau_hat = cate.RLearnerCATE(backend='catboost', n_folds=5, seed=0).fit(ds.X, ds.A, ds.Y)\n",
    "\n",
    "# in-sample sanity check vs. the truth\n",
    "true_vals = ds.tau0(ds.X)\n",
    "pred_vals = tau_hat.predict(ds.X)\n",
    "rmse = float(np.sqrt(np.mean((pred_vals - true_vals) ** 2)))\n",
    "sup = float(np.max(np.abs(pred_vals - true_vals)))\n",
    "print(f'in-sample RMSE = {rmse:.4f}    sup-norm error ~ {sup:.4f}')\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(11, 4))\n",
    "plotting.plot_function_2d(ds.tau0,         title=r'$\\tau_0$',            ax=axes[0])\n",
    "plotting.plot_function_2d(tau_hat.predict, title=r'$\\widehat\\tau_n$', ax=axes[1])\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4f9c0b4f",
   "metadata": {},
   "source": [
